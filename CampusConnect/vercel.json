{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://campus-connect-api-gateway.onrender.com/api/$1"
    },
    {
      "src": "/ws/(.*)",
      "dest": "wss://campus-connect-websocket.onrender.com/ws/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://campus-connect-api-gateway.onrender.com",
    "REACT_APP_WEBSOCKET_URL": "wss://campus-connect-websocket.onrender.com",
    "REACT_APP_ENVIRONMENT": "production"
  },
  "functions": {
    "frontend/src/**/*.js": {
      "maxAge": 86400
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}